upstream ${HOST} {
    server ${HOST}:80;
}

server {
    listen 80;
	client_max_body_size 900M;

    location / {
        proxy_pass http://${HOST};
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $host;
        proxy_redirect off;
    }

   location /static/ {
       alias /var/www/static/;
   }

   location /media/ {
       alias /var/www/media/;
   }

   location /health {
       access_log off;
       return 200 "healthy\n";
   }

}